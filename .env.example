# Copy to .env.local and fill in. .env.local is git-ignored.

# Supabase Postgres — prefer the *pooled* connection string (port 6543, pgbouncer)
# for the app; use the direct one (port 5432) for drizzle-kit migrate.
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# Local Redis from docker-compose. Override in production.
REDIS_URL=redis://localhost:6379

# Google AI Studio API key. Powers BOTH the Q&A agent (Gemini 2.5 Flash)
# AND the embeddings (gemini-embedding-001, 1024 dims).
# https://aistudio.google.com/apikey — free tier, no credit card required.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: raises GitHub clone/API rate limits when set.
GITHUB_TOKEN=
