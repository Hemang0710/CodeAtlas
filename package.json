{
  "name": "codeatlas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "dotenv -e .env.local -- tsx watch src/server/queue/worker.ts",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- tsx scripts/migrate.ts",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "mcp": "dotenv -e .env.local -- tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/react": "^3.0.208",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.206",
    "bullmq": "^5.78.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "ignore": "^7.0.5",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.6.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "~0.22.6",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
